APP_NAME=AgendaPRO Test
APP_ENV=testing
APP_DEBUG=false
APP_URL=http://localhost
APP_KEY=test_key_only_for_testing_not_production

# Banco dedicado para testes — rode: CREATE DATABASE agendapro_test;
# Depois importe o schema: mysql -u root agendapro_test < database/schema.sql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=agendapro_test
DB_USERNAME=root
DB_PASSWORD=

REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

LOG_LEVEL=error
LOG_FILE=storage/logs/test.log
