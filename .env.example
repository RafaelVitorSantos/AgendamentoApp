# ============================================================
# AgendaPRO SaaS — Configurações de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ============================================================

APP_NAME=AgendaPRO
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/AgendamentoApp
APP_KEY=GERE_UMA_CHAVE_ALEATORIA_AQUI_32_CHARS

# Banco de dados
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=agendapro
DB_USERNAME=root
DB_PASSWORD=

# Redis (cache e sessões em produção)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@agendapro.com.br
MAIL_FROM_NAME=AgendaPRO

# WhatsApp API (Evolution API / Z-API)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE=

# Gateway de Pagamento (Asaas)
PAYMENT_GATEWAY=asaas
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox

# JWT
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_AQUI_64_CHARS
JWT_TTL=3600
JWT_REFRESH_TTL=604800

# Sessão
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp

# Log
LOG_LEVEL=debug
LOG_FILE=storage/logs/app.log
